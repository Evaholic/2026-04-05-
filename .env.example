# 复制为 .env.local 后填写真实值。本文件只作说明，不要提交真实密钥。

# ========== Stripe ==========
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
# NEXT_PUBLIC_APP_URL=https://你的线上域名
# STRIPE_WEBHOOK_SECRET=

# ========== Google 登录（OAuth / Auth.js）==========
# 生成: openssl rand -base64 32
AUTH_SECRET=
# 与浏览器访问地址一致，无尾斜杠（本地如 http://localhost:3001，线上如 https://你的域名）
AUTH_URL=
NEXTAUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google 控制台重定向 URI: {AUTH_URL}/api/auth/callback/google

# ========== 三模型（USE_MOCK_API=false）==========
OPENAI_API_KEY=
GEMINI_API_KEY=
DOUBAO_API_KEY=
DOUBAO_MODEL=
