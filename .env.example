# Stripe（测试密钥以 sk_test_ 开头）
STRIPE_SECRET_KEY=
# Dashboard → Products → 价格 → 复制 Price ID（price_...）
STRIPE_PRICE_ID=
# subscription（默认）或 payment（一次性）
# STRIPE_CHECKOUT_MODE=subscription

# 生产环境建议设置，用于 Checkout 成功/取消跳转（含 Vercel 部署）
# NEXT_PUBLIC_APP_URL=https://你的域名

# Webhook（本地可用 stripe listen 转发；上线后在 Dashboard 配置端点）
# STRIPE_WEBHOOK_SECRET=whsec_...

# ========== 三模型真实评估（服务端，勿加 NEXT_PUBLIC_）==========
# 将 lib/constants.ts 中 USE_MOCK_API 设为 false 后，POST /api/evaluate 会调用以下密钥。

# OpenAI（ChatGPT）
OPENAI_API_KEY=
# 可选，默认 gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Google Gemini（AI Studio 创建 API Key）
GEMINI_API_KEY=
# 可选，默认 gemini-2.0-flash；若不可用可改为 gemini-1.5-flash
# GEMINI_MODEL=gemini-2.0-flash

# 豆包：火山引擎方舟 OpenAI 兼容接口
# 控制台创建推理接入点，复制 API Key 与 接入点 Endpoint ID（通常形如 ep-xxxx）
DOUBAO_API_KEY=
DOUBAO_MODEL=
# 可选，默认北京区域兼容地址；若你的接入点在其区域请改官方文档地址
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
