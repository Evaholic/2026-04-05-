# Stripe（测试密钥以 sk_test_ 开头）
STRIPE_SECRET_KEY=
# Dashboard → Products → 价格 → 复制 Price ID（price_...）
STRIPE_PRICE_ID=
# subscription（默认）或 payment（一次性）
# STRIPE_CHECKOUT_MODE=subscription

# 生产环境建议设置，用于 Checkout 成功/取消跳转（含 Vercel 部署）
# NEXT_PUBLIC_APP_URL=https://你的域名

# Webhook（本地可用 stripe listen 转发；上线后在 Dashboard 配置端点）
# STRIPE_WEBHOOK_SECRET=whsec_...
